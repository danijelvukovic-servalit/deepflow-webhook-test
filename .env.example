# Port for the webhook server (Render sets this automatically)
PORT=3000

# GitHub webhook secret (must match the secret configured in GitHub)
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=your_secret_here

# DeepFlow template webhook URL
DEEPFLOW_WEBHOOK_URL=https://api-v2.dev.deepflow.ai8.io/api/public/template-webhook/e0d55ecf-44e0-4a54-9817-d496ee1136d1/db3bad38-f977-4394-849e-9412c8468b86

# Public base URL for this server (needed so DeepFlow can download event data)
# On Render this will be something like: https://deepflow-webhook-bridge.onrender.com
PUBLIC_BASE_URL=
