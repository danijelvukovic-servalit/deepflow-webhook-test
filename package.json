  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/danijelvukovic-servalit/deepflow-webhook-test/issues"
  },
  "homepage": "https://github.com/danijelvukovic-servalit/deepflow-webhook-test#readme",
  "dependencies": {
    "dotenv": "^17.4.1",
    "express": "^5.2.1"
  }
}
